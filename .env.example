DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=easyocr_slip_demo

# Optional: set a persistent storage folder outside the project directory.
# For Windows local MVP, leaving this unset will default to ./storage inside the project.
# EASYOCR_STORAGE_ROOT=C:\path\to\easyocr_demo_storage

# Optional for Flask flash messages / sessions.
FLASK_SECRET_KEY=change-this-to-a-random-secret
